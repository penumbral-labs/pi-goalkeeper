{
  "name": "pi-goalkeeper",
  "version": "0.1.9",
  "description": "Guarded goal tracking and continuation for pi.",
  "type": "module",
  "author": "Penumbral Labs",
  "contributors": [
    "Mitch Fultz (https://github.com/fitchmultz)"
  ],
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "extension",
    "codex",
    "goal",
    "watchdog",
    "guardrails"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/penumbral-labs/pi-goalkeeper.git"
  },
  "bugs": {
    "url": "https://github.com/penumbral-labs/pi-goalkeeper/issues"
  },
  "homepage": "https://github.com/penumbral-labs/pi-goalkeeper#readme",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@types/node": "^25.6.1",
    "tsx": "^4.21.0",
    "typebox": "1.1.38",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
